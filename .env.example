# ------------------------------------------------------------------
# Copy this file to `.env` and fill in real values (local dev).
# On Railway, set these as project Variables instead.
# ------------------------------------------------------------------

# Flask session signing key — use a long random string.
SECRET_KEY=change-me-to-a-long-random-string

# ---- Admin login ----
ADMIN_USERNAME=admin
# Preferred: a hashed password. Generate with:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('yourpassword'))"
ADMIN_PASSWORD_HASH=
# Dev-only fallback (used if ADMIN_PASSWORD_HASH is empty):
ADMIN_PASSWORD=admin123

# ---- Supabase (Postgres + Storage) ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Use the SERVICE ROLE key (Project Settings → API) so admin writes/uploads
# bypass Row Level Security. Keep it secret — never expose it to the browser.
SUPABASE_KEY=
# Public storage bucket for project images (create it in the Supabase dashboard).
SUPABASE_BUCKET=project-images
# Direct Postgres connection string — ONLY needed to run migrations (python migrate.py).
# Supabase -> Project Settings -> Database -> Connection string -> URI.
# e.g. postgresql://postgres:YOUR-PASSWORD@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# ---- Email (Mailtrap SMTP) ----
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER_NAME=Portfolio Contact
MAIL_SENDER_EMAIL=m.tahaofficial007@gmail.com
